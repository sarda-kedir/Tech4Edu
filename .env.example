# Copy this file to .env and fill in your real credentials.
# Never commit your real API key.

# Required for enhanced online AI mode
OPENAI_API_KEY=your_openai_api_key_here

# Optional: choose a GPT model available on your account
OPENAI_MODEL=gpt-4o-mini

# Optional: local/offline model name for Ollama fallback
OFFLINE_MODEL=qwen2.5:3b-instruct
OFFLINE_MODEL_PINNED=1
OFFLINE_MODEL_AUTO_PULL=1

# Optional: Flask secret key override
SECRET_KEY=change-me-in-production
